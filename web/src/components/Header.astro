---
import ThemeToggle from './ThemeToggle.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] dark:border-[#333] bg-[var(--color-cream)]/95 dark:bg-[var(--color-charcoal)]/95 backdrop-blur-sm">
  <div class="flex items-center justify-between h-14 px-4 lg:px-6">
    <div class="flex items-center gap-3">
      <!-- 行動裝置選單切換 -->
      <button
        id="sidebar-toggle"
        type="button"
        aria-label="切換導覽選單"
        class="lg:hidden p-2 -ml-2 rounded-lg hover:bg-[var(--color-beige)] dark:hover:bg-[var(--color-dark-surface)]"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <a href={base} class="flex items-center gap-2 text-[var(--color-charcoal)] dark:text-[var(--color-cream)] hover:text-[var(--color-terracotta)] transition-colors">
        <span class="font-semibold text-sm tracking-tight">Claude Code from Source</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <!-- 專注模式：隱藏側欄以進行無干擾閱讀 -->
      <button
        id="focus-toggle"
        type="button"
        aria-label="切換專注模式"
        title="專注模式 —— 隱藏側欄"
        class="hidden lg:flex p-2 rounded-lg text-[var(--color-charcoal)] dark:text-[var(--color-cream)] hover:bg-[var(--color-beige)] dark:hover:bg-[var(--color-dark-surface)] transition-colors"
      >
        <!-- 展開圖示（側欄可見時顯示） -->
        <svg id="focus-icon-expand" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5" />
        </svg>
        <!-- 收合圖示（專注模式時顯示） -->
        <svg id="focus-icon-collapse" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 4v1M9 4H4m5 0L4 9m11-5v1m0-1h5m-5 0l5 5M9 20v-1m0 1H4m5 0l-5-5m11 5v-1m0 1h5m-5 0l5-5" />
        </svg>
      </button>

      <a
        href="https://github.com/alejandrobalderas/claude-code-from-source"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 rounded-lg text-[var(--color-charcoal)] dark:text-[var(--color-cream)] hover:bg-[var(--color-beige)] dark:hover:bg-[var(--color-dark-surface)] transition-colors"
        aria-label="GitHub 儲存庫"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
